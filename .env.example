# Shree Shyam Dairy Farm — Environment Variables (development template)
# Copy to .env.local for local dev:  cp .env.example .env.local
# Production template: see .env.production.example
# Validate: npm run env:validate

# ═══════════════════════════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT (defaults below — safe for localhost)
# ═══════════════════════════════════════════════════════════════════════════════

APP_ENV=development
NODE_ENV=development
APP_VERSION=0.1.0

# ─── Canonical website URL (frontend + same-origin API) ───
# Frontend:  http://localhost:3000
# API:       http://localhost:3000/api/v1/*
# Admin:     http://localhost:3000/admin
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost

# Do NOT set NEXT_PUBLIC_API_URL — API is same-origin under NEXT_PUBLIC_APP_URL.
# Do NOT set AUTH_URL — not used by this project.

# ─── Database ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shree_shyam?sslmode=disable

# ─── JWT Auth (custom JWT + opaque refresh — NOT NextAuth sessions) ───
JWT_ACCESS_SECRET=your_long_random_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_long_random_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_REFRESH_REMEMBER_EXPIRES=30d

# ─── Admin ───
ADMIN_SECRET=your_secure_admin_secret_min_16_chars

# ─── Redis (optional in dev) ───
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════════════════════
# LEGACY ALIASES (optional — remove in new deployments)
# ═══════════════════════════════════════════════════════════════════════════════
# NEXTAUTH_SECRET=          # Alias for JWT_ACCESS_SECRET (deprecated)
# NEXTAUTH_URL=             # Alias for NEXT_PUBLIC_APP_URL (deprecated — do not use in production)

# ═══════════════════════════════════════════════════════════════════════════════
# PAYMENTS — Razorpay
# ═══════════════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret
# RAZORPAY_WEBHOOK_SECRET=
# Dev webhook (ngrok): https://xxxx.ngrok.io/api/payment/webhook

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL — Resend
# ═══════════════════════════════════════════════════════════════════════════════
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=orders@kunwardairy.com
# ADMIN_NOTIFICATION_EMAIL=admin@kunwardairy.com

# ═══════════════════════════════════════════════════════════════════════════════
# AI — OpenAI (optional)
# ═══════════════════════════════════════════════════════════════════════════════
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ═══════════════════════════════════════════════════════════════════════════════
# MULTI-TENANT
# ═══════════════════════════════════════════════════════════════════════════════
DEFAULT_TENANT_SLUG=default

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════════════════
ENCRYPTION_KEY=your_32_char_encryption_key_here
OTP_SALT=random_otp_salt
ACCOUNT_LOCK_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
BOT_DETECTION_ENABLED=true
GEO_BLOCKING_ENABLED=false
GDPR_RETENTION_DAYS=365
CRON_SECRET=your_cron_secret
METRICS_TOKEN=dev-metrics-token

# ═══════════════════════════════════════════════════════════════════════════════
# FARM / IoT (optional)
# ═══════════════════════════════════════════════════════════════════════════════
FARM_API_KEY_SALT=your_random_salt
API_KEY_SALT=your_api_key_hash_salt
MQTT_BRIDGE_ENABLED=false
MQTT_BROKER_URL=mqtt://localhost:1883
# SSD_CLOUD_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════════
# STORAGE
# ═══════════════════════════════════════════════════════════════════════════════
STORAGE_PROVIDER=local
STORAGE_PUBLIC_URL=/storage

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE OAUTH (optional)
# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google

# ═══════════════════════════════════════════════════════════════════════════════
# STRIPE / SMS / WHATSAPP / WEB PUSH — see .env.production.example
# ═══════════════════════════════════════════════════════════════════════════════
