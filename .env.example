# Shree Shyam Dairy Farm — Environment Variables
# Copy to .env.local and fill in values (never commit .env.local)
# Validated at startup via src/config/env.ts — run: npm run env:validate

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED IN PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL — Neon / Supabase / Railway) ───
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/shree_shyam?sslmode=require

# ─── JWT Auth (production auth — NOT NextAuth) ───
# Min 32 characters each. Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=your_long_random_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_long_random_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_REFRESH_REMEMBER_EXPIRES=30d

# ─── Admin (protects PUT /api/content) ───
# Min 16 characters
ADMIN_SECRET=your_secure_admin_secret

# ─── App URL (OAuth callbacks, emails, Stripe redirects) ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════════
# LEGACY ALIASES (optional — prefer JWT_* and NEXT_PUBLIC_APP_URL above)
# ═══════════════════════════════════════════════════════════════════════════════
# NEXTAUTH_SECRET=          # Alias for JWT_ACCESS_SECRET (deprecated)
# NEXTAUTH_URL=             # Alias for NEXT_PUBLIC_APP_URL (deprecated)

# ═══════════════════════════════════════════════════════════════════════════════
# PAYMENTS — Razorpay (https://dashboard.razorpay.com/app/keys)
# Both keys required together when enabling checkout
# ═══════════════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_TENANT_WEBHOOK_SECRET=
# RAZORPAY_CUSTOMER_CONTACT=9999999999
# RAZORPAY_CUSTOMER_EMAIL=orders@shreeshyamdairyfarm.com

# ═══════════════════════════════════════════════════════════════════════════════
# AI — OpenAI (https://platform.openai.com/api-keys)
# Optional — AI modules degrade gracefully without it
# ═══════════════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL — Resend (https://resend.com)
# RESEND_API_KEY required with EMAIL_FROM when enabling transactional email
# ═══════════════════════════════════════════════════════════════════════════════
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=orders@shreeshyamdairyfarm.com
# ADMIN_NOTIFICATION_EMAIL=admin@shreeshyamdairyfarm.com

# ═══════════════════════════════════════════════════════════════════════════════
# SMS — MSG91 (future / optional order confirmations)
# ═══════════════════════════════════════════════════════════════════════════════
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# RUNTIME
# ═══════════════════════════════════════════════════════════════════════════════
APP_ENV=development
APP_VERSION=0.1.0
NODE_ENV=development

# ─── Redis (cache, sessions, BullMQ) — optional in dev ───
REDIS_URL=redis://localhost:6379

# ─── Multi-Tenant SaaS ───
DEFAULT_TENANT_SLUG=default
NEXT_PUBLIC_APP_DOMAIN=shree-shyam-dairy-farm.vercel.app

# ─── Enterprise Security ───
ENCRYPTION_KEY=your_32_char_encryption_key_here
OTP_SALT=random_otp_salt
ACCOUNT_LOCK_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
BOT_DETECTION_ENABLED=true
GEO_BLOCKING_ENABLED=false
GDPR_RETENTION_DAYS=365

# ─── Farm IoT ───
FARM_API_KEY_SALT=your_random_salt
API_KEY_SALT=your_api_key_hash_salt
SEED_DEVICE_API_KEY=
VISION_WEBHOOK_API_KEY=
MQTT_BRIDGE_ENABLED=false
MQTT_BROKER_URL=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_BROKER_TYPE=MOSQUITTO
# SSD_CLOUD_URL=http://localhost:3000

# ─── File Storage ───
STORAGE_PROVIDER=local
STORAGE_PUBLIC_URL=/storage
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=ssd-uploads
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STORAGE_PROVIDER=r2
# R2_BUCKET_NAME=ssd-uploads
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_DOMAIN=cdn.shreeshyamdairyfarm.com

# ─── Logging (Pino) ───
# LOG_LEVEL=debug
# LOG_PRETTY=true
# LOG_FILE_ENABLED=false
# LOG_FILE_PATH=logs/app.log
# LOG_FILE_SYNC=false
# LOG_SERVICE_NAME=shree-shyam-erp

# ─── Monitoring & Ops ───
SENTRY_DSN=
SENTRY_ENABLED=false
METRICS_TOKEN=dev-metrics-token
CRON_SECRET=your_cron_secret

# ─── SMS OTP — MSG91 ───
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=

# ─── WhatsApp Business Cloud API ───
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=

# ─── Google OAuth ───
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google

# ─── Stripe (tenant billing) ───
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Web Push (PWA) ───
# Generate: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:admin@shreeshyamdairyfarm.com

# ─── Integrations Platform (enable as needed) ───
# PHONEPE_MERCHANT_ID=
# PHONEPE_SALT_KEY=
# PHONEPE_SALT_INDEX=1
# CASHFREE_APP_ID=
# CASHFREE_SECRET_KEY=
# GST_API_KEY=
# GST_GSTIN=
# GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# GA_API_SECRET=
# NEXT_PUBLIC_META_PIXEL_ID=
# FIREBASE_PROJECT_ID=
# FIREBASE_SERVER_KEY=
# SHIPROCKET_EMAIL=
# SHIPROCKET_PASSWORD=
# DELHIVERY_API_TOKEN=
# INDIA_POST_API_KEY=
# SAP_API_URL=
# SAP_CLIENT_ID=
# SAP_CLIENT_SECRET=
# TALLY_SERVER_URL=
# TALLY_COMPANY=
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REALM_ID=

# ─── Geo / IP (optional) ───
# GEO_BLOCK_COUNTRIES=CN,RU
# GEO_ALLOW_COUNTRIES=IN
# GEO_BLOCK_UNKNOWN=false
# IP_WHITELIST=
# IP_BLACKLIST=
# ADMIN_IP_WHITELIST=
