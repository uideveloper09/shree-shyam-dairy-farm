# Copy to .env.local and fill in your values (never commit .env.local)

# ─── Database (PostgreSQL — Neon / Supabase / Railway) ───
DATABASE_URL=postgresql://user:password@host:5432/shree_shyam?sslmode=require

# ─── JWT Auth ───
JWT_ACCESS_SECRET=your_long_random_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_long_random_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_REFRESH_REMEMBER_EXPIRES=30d

# ─── Razorpay — https://dashboard.razorpay.com/app/keys ───
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret

# ─── OpenAI — https://platform.openai.com/api-keys ───
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ─── Admin — protects PUT /api/content ───
ADMIN_SECRET=your_secure_admin_secret

# ─── Email (Phase 2) — https://resend.com ───
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=orders@shreeshyamdairyfarm.com

# ─── SMS OTP (Phase 2) — MSG91 / Twilio ───
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=

# ─── Google OAuth (Phase 2) ───
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
