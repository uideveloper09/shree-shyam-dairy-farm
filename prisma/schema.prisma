// Shree Shyam Dairy Farm — Production E-Commerce Schema
// Run: npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  DELIVERY
  FARM_MANAGER
  VETERINARIAN
  ACCOUNTANT
  IOT_OPERATOR
  OWNER
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
  PHONE
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CONFIRMED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
  RETURN_REQUESTED
}

enum PaymentStatus {
  PENDING
  PAID
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  NETBANKING
  WALLET
  COD
}

enum InventoryMovementType {
  SALE
  RESTOCK
  ADJUSTMENT
  RETURN
  TRANSFER_IN
  TRANSFER_OUT
}

enum SubscriptionFrequency {
  DAILY
  ALTERNATE_DAY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  VACATION
}

enum DeliverySlot {
  MORNING
  EVENING
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum NotificationType {
  TRANSACTIONAL
  MARKETING
  ANNOUNCEMENT
  BROADCAST
  SYSTEM
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationDeliveryStatus {
  PENDING
  SCHEDULED
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  FAILED
  CANCELLED
}

enum AddressType {
  SHIPPING
  BILLING
  BOTH
}

model User {
  id                String         @id @default(cuid())
  email             String?        @unique
  emailVerified     DateTime?
  phone             String?        @unique
  phoneVerified     DateTime?
  passwordHash      String?
  name              String?
  avatar            String?
  role              UserRole       @default(CUSTOMER)
  authProvider      AuthProvider   @default(EMAIL)
  googleId          String?        @unique
  appleId           String?        @unique
  referralCode      String         @unique @default(cuid())
  referredById      String?
  referredBy        User?          @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]         @relation("Referrals")
  walletBalance     Decimal        @default(0) @db.Decimal(10, 2)
  isActive          Boolean        @default(true)
  failedLoginAttempts Int          @default(0)
  lockedUntil       DateTime?
  twoFactorEnabled  Boolean        @default(false)
  totpSecretEnc     String?
  gdprConsentAt     DateTime?
  gdprConsentVersion String?
  deletedAt         DateTime?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  sessions          Session[]
  refreshTokens     RefreshToken[]
  addresses         Address[]
  cart              Cart?
  wishlist          WishlistItem[]
  orders            Order[]
  reviews           Review[]
  subscriptions     Subscription[]
  notifications     Notification[]
  coupons           UserCoupon[]
  walletTxns        WalletTransaction[]
  paymentMethods    SavedPaymentMethod[]
  otpCodes          OtpCode[]
  emailTokens       EmailToken[]
  auditLogs         AuditLog[]
  dataExports       DataExportRequest[]
  pushSubscriptions PushSubscription[]
  offlineSyncRecords OfflineSyncRecord[]
  deliveryAssignments DeliveryAssignment[] @relation("DeliveryAssignee")
  mobileDevices     MobileDevice[]
  webAuthnCredentials WebAuthnCredential[]
  gpsPings          GpsPing[]
  barcodeScans      BarcodeScan[]
  developerAccount  DeveloperAccount?
  tenantMemberships TenantMember[]
  notificationDeliveries NotificationDelivery[]
  notificationBroadcastsCreated NotificationBroadcast[] @relation("BroadcastCreator")
  workflowInstancesRequested WorkflowInstance[] @relation("WorkflowRequester")
  workflowStepsActed WorkflowStepInstance[] @relation("StepActor")
  workflowAuditLogs WorkflowAuditLog[]
  workflowDefinitionsCreated WorkflowDefinition[] @relation("WorkflowCreator")
  expenseRequests ExpenseRequest[]
  purchaseRequests PurchaseRequest[]
  leaveRequests LeaveRequest[]
  refundRequests RefundRequest[]
  subscriptionApprovalRequests SubscriptionApprovalRequest[]
  documentsUploaded Document[] @relation("DocumentUploader")
  documentFoldersCreated DocumentFolder[] @relation("FolderCreator")
  documentSignatures DocumentSignature[]
  crmLeadsAssigned CrmLead[] @relation("LeadAssignee")
  crmLeadsCreated CrmLead[] @relation("LeadCreator")
  crmCustomersOwned CrmCustomer[] @relation("CustomerOwner")
  crmOpportunitiesOwned CrmOpportunity[] @relation("OpportunityOwner")
  crmFollowUpsAssigned CrmFollowUp[] @relation("FollowUpAssignee")
  crmQuotationsCreated CrmQuotation[] @relation("QuotationCreator")
  crmCampaignsOwned CrmCampaign[] @relation("CampaignOwner")
  crmTicketsAssigned CrmSupportTicket[] @relation("TicketAssignee")
  crmTicketsCreated CrmSupportTicket[] @relation("TicketCreator")
  crmTicketMessages CrmTicketMessage[]
  fleetDriverProfile FleetDriver?
  fleetTripsAsDriver FleetTrip[] @relation("TripDriver")
  procBatchesCreated ProcBatch[] @relation("BatchCreator")
  procQualityChecks  ProcQualityCheck[]
  posBillsAsCashier  PosBill[] @relation("PosCashier")
  posLoyaltyAccount  PosLoyaltyAccount?
  aiModuleRuns       AiModuleRun[]
  aiWhatsAppSessions AiWhatsAppSession[]
  partnerMemberships SaasPartnerMember[]

  @@index([passwordResetTokenHash])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String    @unique
  userAgent    String?
  ipAddress    String?
  deviceLabel  String?
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String    @unique
  remember    Boolean   @default(false)
  userAgent   String?
  ipAddress   String?
  deviceLabel String?
  sessionId   String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  @@index([userId])
  @@index([sessionId])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String
  code      String
  purpose   String   // login, verify_phone
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([phone, purpose])
}

model EmailToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  purpose   String   // verify_email, reset_password
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, purpose])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorId    String?
  action     String
  resource   String?
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  severity   String   @default("info")
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model DataExportRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String    @default("pending")
  downloadUrl String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  image       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  legacyId        Int?     @unique // maps to content.json id during migration
  slug            String   @unique
  name            String
  description     String?
  shortDesc       String?
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  price           Decimal  @db.Decimal(10, 2)
  mrp             Decimal? @db.Decimal(10, 2)
  unit            String   @default("unit")
  weight          String?
  images          String[] @default([])
  nutrition       Json?
  benefits        String[] @default([])
  storage         String?
  inStock         Boolean  @default(true)
  stockQty        Int      @default(100)
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount     Int      @default(0)
  isActive        Boolean  @default(true)
  isSubscription  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  orderItems      OrderItem[]
  reviews         Review[]
  subscriptions   Subscription[]

  posBarcodes     PosProductBarcode[]
  posBillItems    PosBillItem[]

  inventoryLevels    InventoryLevel[]
  inventoryMovements InventoryMovement[]

  @@index([categoryId])
  @@index([slug])
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  levels    InventoryLevel[]
  movements InventoryMovement[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryLevel {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)

  @@unique([warehouseId, productId])
  @@index([productId])
}

model InventoryMovement {
  id             String                @id @default(cuid())
  warehouseId    String
  warehouse      Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId      String
  product        Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId        String?
  order          Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type           InventoryMovementType
  quantityChange Int
  quantityBefore Int
  quantityAfter  Int
  reason         String?
  metadata       Json?
  createdAt      DateTime              @default(now())

  @@index([warehouseId])
  @@index([productId])
  @@index([orderId])
}

model Address {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         AddressType @default(SHIPPING)
  name         String
  phone        String
  line1        String
  line2        String?
  city         String
  state        String
  pincode      String
  landmark     String?
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@index([userId])
}

model Cart {
  id         String     @id @default(cuid())
  userId     String     @unique
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestId    String?    @unique
  couponCode String?
  note       String?
  items      CartItem[]
  updatedAt  DateTime   @updatedAt
  createdAt  DateTime   @default(now())
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  type          String       // percent, flat
  value         Decimal      @db.Decimal(10, 2)
  minOrder      Decimal?     @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  usageLimit    Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  userCoupons   UserCoupon[]
  orders        Order[]
}

model UserCoupon {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  couponId  String
  coupon    Coupon    @relation(fields: [couponId], references: [id])
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, couponId])
}

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  userId            String?
  user              User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestEmail        String?
  guestPhone        String?
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  paymentMethod     PaymentMethod?
  subtotal          Decimal       @db.Decimal(10, 2)
  shippingCharge    Decimal       @default(0) @db.Decimal(10, 2)
  discount          Decimal       @default(0) @db.Decimal(10, 2)
  tax               Decimal       @default(0) @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  couponId          String?
  coupon            Coupon?       @relation(fields: [couponId], references: [id])
  couponCode        String?
  note              String?
  deliverySlot      DeliverySlot?
  deliveryDate      DateTime?
  razorpayOrderId   String?
  razorpayPaymentId String?
  paymentCompletedAt DateTime?
  inventoryProcessedAt DateTime?
  confirmationNotifiedAt DateTime?
  shippingAddressId String?
  shippingAddress   Address?      @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId  String?
  billingAddress    Address?      @relation("BillingAddress", fields: [billingAddressId], references: [id])
  invoiceNumber     String?       @unique
  invoiceUrl        String?
  trackingId        String?
  cancelledAt       DateTime?
  deliveredAt       DateTime?
  items             OrderItem[]
  payments          Payment[]
  inventoryMovements InventoryMovement[]
  deliveryAssignment DeliveryAssignment?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  unit      String?

  @@index([orderId])
}

model Payment {
  id                   String        @id @default(cuid())
  orderId              String
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId           String?
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @default("INR")
  method               PaymentMethod
  status               PaymentStatus @default(PENDING)
  razorpayPaymentId    String?       @unique
  razorpayOrderId      String?
  razorpaySignature    String?
  paymentDate          DateTime      @default(now())
  transactionReference String?
  refundId             String?
  refundAmount         Decimal?      @db.Decimal(10, 2)
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([orderId])
  @@index([customerId])
}

/// Auditable log of inbound Razorpay webhook events (storefront payments).
model RazorpayWebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  eventType String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([processed])
  @@index([createdAt])
}

model SavedPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  last4     String?
  brand     String?
  token     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Subscription {
  id            String                @id @default(cuid())
  userId        String
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     String
  product       Product               @relation(fields: [productId], references: [id])
  frequency     SubscriptionFrequency
  status        SubscriptionStatus    @default(ACTIVE)
  quantity      Int                   @default(1)
  deliverySlot  DeliverySlot          @default(MORNING)
  customDays    Int[]                 @default([])
  startDate     DateTime
  nextDelivery  DateTime?
  pausedUntil   DateTime?
  vacationUntil DateTime?
  addressId     String?
  razorpaySubId String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  deliveries    SubscriptionDelivery[]

  @@index([userId])
  @@index([status])
}

model SubscriptionDelivery {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  scheduledDate  DateTime
  deliveredAt    DateTime?
  skipped        Boolean      @default(false)
  status         String       @default("scheduled")
  createdAt      DateTime     @default(now())

  @@index([subscriptionId, scheduledDate])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  rating    Int
  title     String?
  comment   String?
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
}

model Notification {
  id           String                @id @default(cuid())
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel      NotificationChannel   @default(IN_APP)
  type         NotificationType      @default(TRANSACTIONAL)
  priority     NotificationPriority  @default(NORMAL)
  title        String
  body         String
  data         Json?
  readAt       DateTime?
  sentAt       DateTime?
  deliveryId   String?
  delivery     NotificationDelivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  broadcastId  String?
  broadcast    NotificationBroadcast? @relation(fields: [broadcastId], references: [id], onDelete: SetNull)
  createdAt    DateTime              @default(now())

  @@index([userId, readAt])
  @@index([broadcastId])
}

// ─── Mobile Platform ────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model OfflineSyncRecord {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  action    String
  payload   Json
  status    String    @default("pending")
  syncedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, status])
  @@unique([clientId])
}

model DeliveryAssignment {
  id            String    @id @default(cuid())
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assigneeId    String
  assignee      User      @relation("DeliveryAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  status        String    @default("assigned")
  latitude      Decimal?  @db.Decimal(10, 7)
  longitude     Decimal?  @db.Decimal(10, 7)
  proofPhotoUrl String?
  scannedAt     DateTime?
  deliveredAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([assigneeId, status])
}

model MobileDevice {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId          String
  platform          String?
  pushEnabled       Boolean  @default(false)
  biometricEnabled  Boolean  @default(false)
  lastSeenAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  @@unique([userId, deviceId])
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    String
  counter      Int      @default(0)
  deviceLabel  String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model GpsPing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  accuracy  Float?
  context   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model BarcodeScan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     String
  format    String?
  context   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Developer API Platform ─────────────────────────────────────────────────

model DeveloperAccount {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   String?
  website   String?
  tier      String   @default("free")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  apiKeys   ApiKey[]
  webhooks  WebhookEndpoint[]
}

model ApiKey {
  id          String           @id @default(cuid())
  developerId String
  developer   DeveloperAccount @relation(fields: [developerId], references: [id], onDelete: Cascade)
  name        String
  keyPrefix   String
  keyHash     String           @unique
  scopes      String[]         @default([])
  rateLimit   Int              @default(60)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime         @default(now())

  @@index([developerId])
  @@index([keyPrefix])
}

model WebhookEndpoint {
  id          String           @id @default(cuid())
  developerId String
  developer   DeveloperAccount @relation(fields: [developerId], references: [id], onDelete: Cascade)
  url         String
  secret      String
  events      String[]         @default([])
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deliveries  WebhookDelivery[]

  @@index([developerId])
}

model WebhookDelivery {
  id           String          @id @default(cuid())
  endpointId   String
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event        String
  payload      Json
  status       String          @default("pending")
  statusCode   Int?
  responseBody String?
  attempts     Int             @default(0)
  nextRetryAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime        @default(now())

  @@index([endpointId, status])
  @@index([event, createdAt])
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(10, 2)
  type        String   // credit, debit
  description String
  referenceId String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// ─── Farm IoT / AI Platform ─────────────────────────────────────────────────

enum FarmAutonomyMode {
  MANUAL
  SEMI_AUTO
  AUTONOMOUS
}

enum IoTDeviceStatus {
  ONLINE
  OFFLINE
  DEGRADED
  MAINTENANCE
}

enum GatewayStatus {
  PROVISIONED
  ONLINE
  OFFLINE
  DEGRADED
  REVOKED
}

enum PredictionDomain {
  MILK
  DEMAND
  INVENTORY
  PROFIT
  DISEASE
  WEATHER_IMPACT
  PRODUCTION_PLAN
  FINANCE
  MARKETING
  SALES
  CUSTOMER
  CEO
}

model IoTDevice {
  id          String          @id @default(cuid())
  farmId      String          @default("default")
  deviceKey   String          @unique
  name        String
  type        String          @default("SENSOR")
  status      IoTDeviceStatus @default(OFFLINE)
  apiKeyHash  String?
  gatewayId   String?
  metadata    Json?
  lastSeenAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  readings    SensorReading[]

  @@index([farmId, status])
}

model SensorReading {
  id             String    @id @default(cuid())
  deviceId       String
  device         IoTDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  sensorKey      String
  sensorType     String
  value          Float
  unit           String?
  recordedAt     DateTime
  idempotencyKey String?   @unique
  source         String    @default("HTTP")
  createdAt      DateTime  @default(now())

  @@index([deviceId, sensorKey, recordedAt])
}

model EdgeGateway {
  id           String        @id @default(cuid())
  farmId       String        @default("default")
  gatewayKey   String        @unique
  name         String
  platform     String        @default("RASPBERRY_PI")
  status       GatewayStatus @default(PROVISIONED)
  apiKeyHash   String
  configVersion Int          @default(1)
  config       Json?
  lastSeenAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  heartbeats   GatewayHeartbeat[]

  @@index([farmId, status])
}

model GatewayHeartbeat {
  id         String      @id @default(cuid())
  gatewayId  String
  gateway    EdgeGateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  status     GatewayStatus
  queueDepth Int         @default(0)
  connectivity Json?
  recordedAt DateTime    @default(now())

  @@index([gatewayId, recordedAt])
}

model MqttOfflineMessage {
  id          String    @id @default(cuid())
  topic       String
  payload     String    @db.Text
  qos         Int       @default(1)
  direction   String
  retryCount  Int       @default(0)
  maxRetries  Int       @default(5)
  nextRetryAt DateTime?
  status      String    @default("PENDING")
  lastError   String?
  createdAt   DateTime  @default(now())

  @@index([status, nextRetryAt])
}

model FarmAutonomyConfig {
  id              String           @id @default(cuid())
  farmId          String           @unique @default("default")
  mode            FarmAutonomyMode @default(SEMI_AUTO)
  dryRun          Boolean          @default(false)
  maintenanceMode Boolean          @default(false)
  emergencyStop   Boolean          @default(false)
  updatedAt       DateTime         @updatedAt
}

model AutomationRule {
  id           String   @id @default(cuid())
  farmId       String   @default("default")
  name         String
  templateKey  String
  status       String   @default("ACTIVE")
  priority     Int      @default(100)
  conditions   Json
  actions      Json
  cooldownSec  Int      @default(300)
  sensorKeys   String[] @default([])
  actuatorKeys String[] @default([])
  schedule     String?
  requiresAck  Boolean  @default(false)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  logs         AutomationLog[]

  @@index([farmId, status])
}

model ActuatorDevice {
  id            String   @id @default(cuid())
  farmId        String   @default("default")
  deviceKey     String   @unique
  name          String
  type          String
  state         String   @default("UNKNOWN")
  value         Float?
  lastCommandAt DateTime?
  lastFeedbackAt DateTime?
  metadata      Json?
  updatedAt     DateTime @updatedAt
}

model MilkTankMonitor {
  id            String   @id @default(cuid())
  farmId        String   @default("default")
  tankKey       String   @unique
  name          String
  levelPercent  Float?
  tempC         Float?
  chillerOn     Boolean?
  alertThreshold Json?
  lastReadingAt DateTime?
  updatedAt     DateTime @updatedAt
}

model AutomationLog {
  id        String         @id @default(cuid())
  ruleId    String
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  result    String
  trigger   Json
  actions   Json
  error     String?
  createdAt DateTime       @default(now())

  @@index([ruleId, createdAt])
}

model EmergencyEvent {
  id             String    @id @default(cuid())
  farmId         String    @default("default")
  severity       String
  source         String
  title          String
  message        String
  payload        Json?
  sirenTriggered Boolean   @default(false)
  notifiedAt     DateTime?
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt      DateTime  @default(now())

  @@index([farmId, severity, createdAt])
}

model WeatherStation {
  id          String   @id @default(cuid())
  farmId      String   @default("default")
  stationKey  String   @unique
  name        String
  status      String   @default("OFFLINE")
  apiKeyHash  String?
  latitude    Float?
  longitude   Float?
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  readings    WeatherReading[]
}

model WeatherReading {
  id             String         @id @default(cuid())
  stationId      String
  station        WeatherStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  sensorType     String
  value          Float
  unit           String?
  recordedAt     DateTime
  idempotencyKey String?        @unique
  createdAt      DateTime       @default(now())

  @@index([stationId, recordedAt])
}

model CctvCamera {
  id            String   @id @default(cuid())
  farmId        String   @default("default")
  cameraKey     String   @unique
  name          String
  location      String?
  status        String   @default("OFFLINE")
  streamUrl     String?
  motionEnabled Boolean  @default(true)
  intruderEnabled Boolean @default(true)
  lastSeenAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  events        CctvEvent[]
}

model CctvEvent {
  id         String     @id @default(cuid())
  cameraId   String
  camera     CctvCamera @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  type       String
  severity   String     @default("INFO")
  confidence Float?
  payload    Json?
  occurredAt DateTime
  createdAt  DateTime   @default(now())

  @@index([cameraId, occurredAt])
}

model VisionDetection {
  id        String   @id @default(cuid())
  farmId    String   @default("default")
  cameraKey String?
  pipeline  String
  class     String
  confidence Float
  payload   Json?
  detectedAt DateTime
  createdAt DateTime @default(now())

  @@index([farmId, detectedAt])
}

model PredictionModel {
  id        String   @id @default(cuid())
  key       String   @unique
  domain    PredictionDomain
  version   String
  config    Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  predictions AIPrediction[]
}

model AIPrediction {
  id          String           @id @default(cuid())
  modelId     String?
  model       PredictionModel? @relation(fields: [modelId], references: [id])
  domain      PredictionDomain
  horizon     String
  entityType  String?
  entityId    String?
  farmId      String           @default("default")
  pointValue  Float?
  valueLow    Float?
  valueHigh   Float?
  valueJson   Json?
  confidence  Float?
  validFrom   DateTime
  validTo     DateTime
  createdAt   DateTime         @default(now())

  @@index([domain, farmId, validFrom])
}

model AIRecommendation {
  id        String   @id @default(cuid())
  farmId    String   @default("default")
  userId    String?
  type      String
  title     String
  summary   String
  payload   Json
  confidence Float?
  createdAt DateTime @default(now())

  @@index([farmId, createdAt])
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  farmId    String   @default("default")
  title     String?
  locale    String   @default("hi-IN")
  channel   String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  AIConversationMessage[]

  @@index([userId, updatedAt])
}

model AIConversationMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String         @db.Text
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

model AIInsight {
  id          String   @id @default(cuid())
  farmId      String   @default("default")
  type        String
  title       String
  narrative   String?  @db.Text
  score       Float?
  payload     Json
  generatedAt DateTime @default(now())

  @@index([farmId, type, generatedAt])
}

model AIAlert {
  id          String   @id @default(cuid())
  farmId      String   @default("default")
  severity    String
  title       String
  message     String
  payload     Json?
  acknowledgedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([farmId, severity, createdAt])
}

model VoiceProfile {
  id            String  @id @default(cuid())
  userId        String  @unique
  preferredLocale String @default("HI_IN")
  offlineEnabled Boolean @default(true)
  voiceNotificationsEnabled Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VoiceSession {
  id        String   @id @default(cuid())
  userId    String?
  locale    String   @default("HI_IN")
  channel   String   @default("admin")
  offline   Boolean  @default(false)
  startedAt DateTime @default(now())
  transcripts VoiceTranscript[]

  @@index([userId, startedAt])
}

model VoiceTranscript {
  id        String       @id @default(cuid())
  sessionId String
  session   VoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  direction String
  text      String       @db.Text
  locale    String
  createdAt DateTime     @default(now())

  @@index([sessionId, createdAt])
}

model AgentRun {
  id        String   @id @default(cuid())
  userId    String
  farmId    String   @default("default")
  prompt    String   @db.Text
  status    String   @default("RUNNING")
  result    String?  @db.Text
  steps     Json?
  createdAt DateTime @default(now())
  completedAt DateTime?
  actions   AgentAction[]

  @@index([userId, createdAt])
}

model AgentAction {
  id              String   @id @default(cuid())
  runId           String
  run             AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  toolName        String
  parameters      Json
  status          String   @default("PENDING")
  requiresConfirm Boolean  @default(false)
  confirmToken    String?  @unique
  result          Json?
  createdAt       DateTime @default(now())

  @@index([runId])
}

model PredictionSnapshot {
  id          String           @id @default(cuid())
  domain      PredictionDomain
  horizon     String
  entityType  String?
  entityId    String?
  farmId      String           @default("default")
  pointValue  Float?
  valueLow    Float?
  valueHigh   Float?
  valueJson   Json?
  unit        String?
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime         @default(now())

  @@index([domain, farmId, periodStart])
}

model ProductionPlan {
  id              String   @id @default(cuid())
  farmId          String   @default("default")
  planDate        DateTime @db.Date
  horizonDays     Int      @default(7)
  milkForecastL   Float
  demandForecastL Float
  surplusDeficitL Float
  payload         Json
  createdAt       DateTime @default(now())

  @@unique([farmId, planDate, horizonDays])
}

model Cow {
  id        String   @id @default(cuid())
  farmId    String   @default("default")
  tagNumber String
  name      String?
  breed     String?
  status    String   @default("ACTIVE")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, tagNumber])
  @@index([farmId, status])
}

// ─── Multi-Tenant SaaS Platform ─────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  plan      String   @default("starter")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branding     TenantBranding?
  theme        TenantTheme?
  localeConfig TenantLocaleConfig?
  domains      TenantDomain[]
  subscription TenantBillingSubscription?
  members      TenantMember[]
  usageRecords UsageRecord[]
  analytics    TenantDailyAnalytics[]
  notificationTemplates NotificationTemplate[]
  notificationRules     NotificationRule[]
  notificationJobs      NotificationJob[]
  notificationBroadcasts  NotificationBroadcast[]
  notificationAnalytics   NotificationDailyAnalytics[]
  workflowDefinitions     WorkflowDefinition[]
  workflowInstances       WorkflowInstance[]
  documentFolders         DocumentFolder[]
  documents               Document[]
  integrationConnections  IntegrationConnection[]
  crmPipelines            CrmPipeline[]
  crmLeads                CrmLead[]
  crmCustomers            CrmCustomer[]
  crmOpportunities        CrmOpportunity[]
  crmCampaigns            CrmCampaign[]
  crmQuotations           CrmQuotation[]
  crmTickets              CrmSupportTicket[]
  fleetVehicles           FleetVehicle[]
  fleetDrivers            FleetDriver[]
  fleetRoutes             FleetRoute[]
  procRecipes             ProcRecipe[]
  procBatches             ProcBatch[]
  procSchedules           ProcSchedule[]
  posTerminals            PosTerminal[]
  posBills                PosBill[]
  regionalSettings        TenantRegionalSettings?
  taxRules                TenantTaxRule[]
  shippingZones           TenantShippingZone[]
  marketplaceInstalls     SaasMarketplaceInstall[]
  partnerLinks            SaasPartnerTenant[]
}

model TenantMember {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("member")
  createdAt DateTime @default(now())

  @@unique([tenantId, userId])
  @@index([userId])
}

model TenantBranding {
  tenantId     String  @id
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl      String?
  faviconUrl   String?
  companyName  String?
  tagline      String?
  supportEmail String?
  supportPhone String?
}

model TenantTheme {
  tenantId        String  @id
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  primaryColor    String  @default("#082F63")
  accentColor     String  @default("#C89B3C")
  backgroundColor String  @default("#faf9f6")
  textColor       String  @default("#1a1a1a")
  fontHeading     String?
  fontBody        String?
  customCss       String?
}

model TenantDomain {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domain     String    @unique
  isPrimary  Boolean   @default(false)
  verifiedAt DateTime?
  verifyToken String?
  sslStatus  String    @default("pending")
  createdAt  DateTime  @default(now())

  @@index([tenantId])
}

model TenantLocaleConfig {
  tenantId       String   @id
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultLocale  String   @default("en")
  enabledLocales String[] @default(["en", "hi"])
}

model TenantBillingSubscription {
  id                     String    @id @default(cuid())
  tenantId               String    @unique
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                   String    @default("starter")
  status                 String    @default("trialing")
  billingProvider        String?
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  razorpayCustomerId     String?
  razorpaySubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  trialEndsAt            DateTime?
  updatedAt              DateTime  @updatedAt
}

model UsageRecord {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metric      String
  quantity    Int       @default(1)
  periodStart DateTime
  periodEnd   DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([tenantId, metric, periodStart])
}

model TenantDailyAnalytics {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  orders      Int      @default(0)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)
  activeUsers Int      @default(0)
  apiCalls    Int      @default(0)

  @@unique([tenantId, date])
  @@index([tenantId, date])
}

// ─── Notification Platform ──────────────────────────────────────────────────

model NotificationTemplate {
  id        String              @id @default(cuid())
  tenantId  String?
  tenant    Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug      String
  name      String
  channel   NotificationChannel
  type      NotificationType    @default(TRANSACTIONAL)
  subject   String?
  body      String
  variables Json?
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  rules     NotificationRule[]
  jobs      NotificationJob[]

  @@unique([tenantId, slug, channel])
  @@index([tenantId, isActive])
}

model NotificationRule {
  id         String               @id @default(cuid())
  tenantId   String?
  tenant     Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  event      String
  conditions Json?
  templateId String
  template   NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  channels   Json
  priority   NotificationPriority @default(NORMAL)
  isActive   Boolean              @default(true)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([tenantId, event, isActive])
}

model NotificationJob {
  id             String                   @id @default(cuid())
  tenantId       String?
  tenant         Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type           NotificationType         @default(TRANSACTIONAL)
  priority       NotificationPriority     @default(NORMAL)
  status         NotificationDeliveryStatus @default(PENDING)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  audienceType   String
  audienceFilter Json?
  templateId     String?
  template       NotificationTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  channel        NotificationChannel?
  payload        Json
  createdById    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deliveries     NotificationDelivery[]

  @@index([status, scheduledAt])
  @@index([tenantId, createdAt])
}

model NotificationDelivery {
  id          String                     @id @default(cuid())
  jobId       String?
  job         NotificationJob?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId    String?
  channel     NotificationChannel
  type        NotificationType           @default(TRANSACTIONAL)
  recipient   String?
  title       String
  body        String
  status      NotificationDeliveryStatus @default(PENDING)
  priority    NotificationPriority       @default(NORMAL)
  attempts    Int                        @default(0)
  maxAttempts Int                        @default(5)
  lastError   String?
  providerId  String?
  metadata    Json?
  sentAt      DateTime?
  deliveredAt DateTime?
  nextRetryAt DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  inApp       Notification[]

  @@index([status, nextRetryAt])
  @@index([userId, channel])
  @@index([tenantId, createdAt])
  @@index([jobId])
}

model NotificationBroadcast {
  id             String                     @id @default(cuid())
  tenantId       String?
  tenant         Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title          String
  body           String
  channels       Json
  audienceFilter Json?
  type           NotificationType           @default(BROADCAST)
  priority       NotificationPriority       @default(NORMAL)
  status         NotificationDeliveryStatus @default(PENDING)
  scheduledAt    DateTime?
  sentAt         DateTime?
  stats          Json?
  createdById    String?
  createdBy      User?                      @relation("BroadcastCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  notifications  Notification[]

  @@index([tenantId, status])
  @@index([scheduledAt])
}

model NotificationDailyAnalytics {
  id        String              @id @default(cuid())
  tenantId  String?
  tenant    Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date      DateTime            @db.Date
  channel   NotificationChannel
  sent      Int                 @default(0)
  delivered Int                 @default(0)
  failed    Int                 @default(0)
  opened    Int                 @default(0)

  @@unique([tenantId, date, channel])
  @@index([tenantId, date])
}

// ─── Approval Workflow Platform ─────────────────────────────────────────────

enum WorkflowType {
  EXPENSE
  PURCHASE
  LEAVE
  REFUND
  SUBSCRIPTION
  CUSTOM
}

enum WorkflowInstanceStatus {
  DRAFT
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  ESCALATED
}

enum WorkflowStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
  DELEGATED
}

enum WorkflowTriggerType {
  MANUAL
  EVENT
  SCHEDULE
  CONDITION
}

enum LeaveType {
  SICK
  CASUAL
  EARNED
  UNPAID
  OTHER
}

model WorkflowDefinition {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug        String
  name        String
  type        WorkflowType
  description String?
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  visual      Json?
  createdById String?
  createdBy   User?    @relation("WorkflowCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  steps       WorkflowStepDefinition[]
  triggers    WorkflowTrigger[]
  conditions  WorkflowCondition[]
  automationRules WorkflowAutomationRule[]
  instances   WorkflowInstance[]

  @@unique([tenantId, slug])
  @@index([type, isActive])
}

model WorkflowStepDefinition {
  id             String             @id @default(cuid())
  workflowId     String
  workflow       WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  order          Int
  name           String
  approverRole   String?
  approverUserId String?
  minAmount      Decimal?           @db.Decimal(12, 2)
  maxAmount      Decimal?           @db.Decimal(12, 2)
  autoApprove    Boolean            @default(false)
  escalateHours  Int?
  createdAt      DateTime           @default(now())

  @@index([workflowId, order])
}

model WorkflowTrigger {
  id         String              @id @default(cuid())
  workflowId String
  workflow   WorkflowDefinition  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type       WorkflowTriggerType @default(MANUAL)
  event      String?
  schedule   String?
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())

  @@index([workflowId, event])
}

model WorkflowCondition {
  id         String             @id @default(cuid())
  workflowId String
  workflow   WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  field      String
  operator   String
  value      Json
  logicGroup String             @default("AND")
  createdAt  DateTime           @default(now())

  @@index([workflowId])
}

model WorkflowAutomationRule {
  id         String             @id @default(cuid())
  workflowId String
  workflow   WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  name       String
  event      String
  conditions Json?
  action     String
  isActive   Boolean            @default(true)
  createdAt  DateTime           @default(now())

  @@index([event, isActive])
}

model WorkflowInstance {
  id           String                 @id @default(cuid())
  workflowId   String
  workflow     WorkflowDefinition     @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  tenantId     String?
  tenant       Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type         WorkflowType
  status       WorkflowInstanceStatus @default(PENDING)
  resourceType String
  resourceId   String
  requesterId  String
  requester    User                   @relation("WorkflowRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  title        String
  payload      Json
  currentStep  Int                    @default(0)
  completedAt  DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  steps        WorkflowStepInstance[]
  auditLogs    WorkflowAuditLog[]

  @@index([requesterId, status])
  @@index([type, status])
  @@index([resourceType, resourceId])
  @@index([tenantId, createdAt])
}

model WorkflowStepInstance {
  id           String               @id @default(cuid())
  instanceId   String
  instance     WorkflowInstance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepDefId    String?
  order        Int
  name         String
  status       WorkflowStepStatus   @default(PENDING)
  assigneeRole String?
  assigneeId   String?
  actedById    String?
  actedBy      User?                @relation("StepActor", fields: [actedById], references: [id], onDelete: SetNull)
  comment      String?
  actedAt      DateTime?
  dueAt        DateTime?
  createdAt    DateTime             @default(now())

  @@index([instanceId, order])
  @@index([assigneeRole, status])
  @@index([assigneeId, status])
}

model WorkflowAuditLog {
  id         String           @id @default(cuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  fromStatus String?
  toStatus   String?
  stepOrder  Int?
  comment    String?
  metadata   Json?
  createdAt  DateTime         @default(now())

  @@index([instanceId, createdAt])
  @@index([userId])
}

model ExpenseRequest {
  id          String                 @id @default(cuid())
  requesterId String
  requester   User                   @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  tenantId    String?
  category    String
  amount      Decimal                @db.Decimal(12, 2)
  currency    String                 @default("INR")
  description String?
  receiptUrl  String?
  status      WorkflowInstanceStatus @default(PENDING)
  instanceId  String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([requesterId, status])
}

model PurchaseRequest {
  id          String                 @id @default(cuid())
  requesterId String
  requester   User                   @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  tenantId    String?
  vendor      String?
  items       Json
  totalAmount Decimal                @db.Decimal(12, 2)
  currency    String                 @default("INR")
  notes       String?
  status      WorkflowInstanceStatus @default(PENDING)
  instanceId  String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([requesterId, status])
}

model LeaveRequest {
  id          String                 @id @default(cuid())
  requesterId String
  requester   User                   @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  tenantId    String?
  leaveType   LeaveType              @default(CASUAL)
  startDate   DateTime               @db.Date
  endDate     DateTime               @db.Date
  reason      String?
  status      WorkflowInstanceStatus @default(PENDING)
  instanceId  String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([requesterId, status])
}

model RefundRequest {
  id          String                 @id @default(cuid())
  requesterId String
  requester   User                   @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  orderId     String?
  orderNumber String?
  amount      Decimal                @db.Decimal(12, 2)
  reason      String
  status      WorkflowInstanceStatus @default(PENDING)
  instanceId  String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([requesterId, status])
  @@index([orderNumber])
}

model SubscriptionApprovalRequest {
  id             String                 @id @default(cuid())
  requesterId    String
  requester      User                   @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  subscriptionId String?
  action         String
  reason         String?
  status         WorkflowInstanceStatus @default(PENDING)
  instanceId     String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([requesterId, status])
}

// ─── Document Management System ───────────────────────────────────────────────

enum DocumentCategory {
  GENERAL
  INVOICE
  CERTIFICATE
  VACCINATION
  PURCHASE_BILL
  EMPLOYEE
  CONTRACT
}

model DocumentFolder {
  id          String           @id @default(cuid())
  tenantId    String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    DocumentFolder[] @relation("FolderTree")
  name        String
  slug        String
  path        String
  createdById String
  createdBy   User             @relation("FolderCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  documents   Document[]

  @@unique([tenantId, path])
  @@index([parentId])
  @@index([tenantId, slug])
}

model Document {
  id             String           @id @default(cuid())
  tenantId       String?
  tenant         Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  folderId       String?
  folder         DocumentFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  category       DocumentCategory @default(GENERAL)
  title          String
  fileName       String
  mimeType       String
  sizeBytes      Int
  storageKey     String
  storageUrl     String
  currentVersion Int              @default(1)
  uploadedById   String
  uploadedBy     User             @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  metadata       Json?
  tags           Json?
  isArchived     Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  versions       DocumentVersion[]
  signatures     DocumentSignature[]
  ocrResults     DocumentOcrResult[]

  @@index([tenantId, category])
  @@index([folderId])
  @@index([uploadedById])
}

model DocumentVersion {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version      Int
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  storageUrl   String
  uploadedById String
  changeNote   String?
  createdAt    DateTime @default(now())

  @@unique([documentId, version])
  @@index([documentId])
}

model DocumentSignature {
  id            String   @id @default(cuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version       Int
  signerId      String
  signer        User     @relation(fields: [signerId], references: [id], onDelete: Cascade)
  signerName    String
  signatureHash String
  signatureData String?
  signedAt      DateTime @default(now())
  ipAddress     String?
  verified      Boolean  @default(true)

  @@index([documentId])
  @@index([signerId])
}

model DocumentOcrResult {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    Int
  text       String?  @db.Text
  fields     Json?
  confidence Float?
  provider   String   @default("openai")
  createdAt  DateTime @default(now())

  @@index([documentId, version])
}

// ─── Integrations Platform ────────────────────────────────────────────────────

enum IntegrationProvider {
  RAZORPAY
  PHONEPE
  CASHFREE
  GST
  WHATSAPP
  GOOGLE_MAPS
  FIREBASE
  GOOGLE_ANALYTICS
  META_PIXEL
  SHIPROCKET
  DELHIVERY
  INDIA_POST
  SAP
  TALLY
  QUICKBOOKS
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING_SETUP
}

model IntegrationConnection {
  id             String              @id @default(cuid())
  tenantId       String?
  tenant         Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider       IntegrationProvider
  name           String
  status         IntegrationStatus   @default(PENDING_SETUP)
  config         Json?
  credentialsEnc String?
  metadata       Json?
  lastSyncAt     DateTime?
  lastError      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([tenantId, provider])
  @@index([provider, status])
}

model IntegrationPlugin {
  id          String               @id @default(cuid())
  slug        String               @unique
  name        String
  version     String               @default("1.0.0")
  provider    IntegrationProvider?
  description String?
  entryPoint  String
  hooks       Json
  isEnabled   Boolean              @default(true)
  config      Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model IntegrationEventLog {
  id        String              @id @default(cuid())
  tenantId  String?
  provider  IntegrationProvider
  direction String
  event     String
  status    String
  payload   Json?
  response  Json?
  createdAt DateTime            @default(now())

  @@index([provider, createdAt])
  @@index([tenantId, createdAt])
}

// ─── CRM Platform ─────────────────────────────────────────────────────────────

enum CrmLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum CrmOpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum CrmQuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum CrmCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum CrmTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum CrmTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CrmFollowUpType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  VISIT
  OTHER
}

model CrmPipeline {
  id        String             @id @default(cuid())
  tenantId  String?
  tenant    Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  isDefault Boolean            @default(false)
  stages    CrmPipelineStage[]
  createdAt DateTime           @default(now())

  @@unique([tenantId, slug])
}

model CrmPipelineStage {
  id            String           @id @default(cuid())
  pipelineId    String
  pipeline      CrmPipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name          String
  order         Int
  probability   Int              @default(0)
  opportunities CrmOpportunity[]

  @@index([pipelineId, order])
}

model CrmLead {
  id           String        @id @default(cuid())
  tenantId     String?
  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  phone        String?
  company      String?
  source       String?
  status       CrmLeadStatus @default(NEW)
  score        Int           @default(0)
  notes        String?
  assigneeId   String?
  assignee     User?         @relation("LeadAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?         @relation("LeadCreator", fields: [createdById], references: [id], onDelete: SetNull)
  convertedAt  DateTime?
  customerId   String?
  customer     CrmCustomer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  followUps    CrmFollowUp[]

  @@index([tenantId, status])
  @@index([assigneeId])
}

model CrmCustomer {
  id            String           @id @default(cuid())
  tenantId      String?
  tenant        Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String?          @unique
  name          String
  email         String?
  phone         String?
  company       String?
  address       String?
  tags          Json?
  lifetimeValue Decimal          @default(0) @db.Decimal(12, 2)
  ownerId       String?
  owner         User?            @relation("CustomerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  leads         CrmLead[]
  opportunities CrmOpportunity[]
  quotations    CrmQuotation[]
  tickets       CrmSupportTicket[]
  referrals     CrmReferral[]

  @@index([tenantId])
  @@index([email])
}

model CrmOpportunity {
  id            String             @id @default(cuid())
  tenantId      String?
  tenant        Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title         String
  customerId    String?
  customer      CrmCustomer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  leadId        String?
  stage         CrmOpportunityStage @default(PROSPECTING)
  stageId       String?
  pipelineStage CrmPipelineStage?  @relation(fields: [stageId], references: [id], onDelete: SetNull)
  amount        Decimal            @default(0) @db.Decimal(12, 2)
  probability   Int                @default(10)
  expectedClose DateTime?          @db.Date
  ownerId       String?
  owner         User?              @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  notes         String?
  closedAt      DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  followUps     CrmFollowUp[]
  quotations    CrmQuotation[]

  @@index([tenantId, stage])
  @@index([ownerId])
  @@index([customerId])
}

model CrmFollowUp {
  id            String          @id @default(cuid())
  type          CrmFollowUpType @default(CALL)
  subject       String
  notes         String?
  scheduledAt   DateTime
  completedAt   DateTime?
  isCompleted   Boolean         @default(false)
  leadId        String?
  lead          CrmLead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  assigneeId    String?
  assignee      User?           @relation("FollowUpAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())

  @@index([assigneeId, scheduledAt])
  @@index([isCompleted, scheduledAt])
}

model CrmQuotation {
  id            String             @id @default(cuid())
  tenantId      String?
  tenant        Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quoteNumber   String             @unique
  customerId    String?
  customer      CrmCustomer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  opportunityId String?
  opportunity   CrmOpportunity?    @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  status        CrmQuotationStatus @default(DRAFT)
  subtotal      Decimal            @default(0) @db.Decimal(12, 2)
  tax           Decimal            @default(0) @db.Decimal(12, 2)
  total         Decimal            @default(0) @db.Decimal(12, 2)
  validUntil    DateTime?          @db.Date
  notes         String?
  createdById   String?
  createdBy     User?              @relation("QuotationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  sentAt        DateTime?
  acceptedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  lines         CrmQuotationLine[]

  @@index([tenantId, status])
  @@index([customerId])
}

model CrmQuotationLine {
  id          String       @id @default(cuid())
  quotationId String
  quotation   CrmQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal      @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal      @db.Decimal(10, 2)
  amount      Decimal      @db.Decimal(12, 2)

  @@index([quotationId])
}

model CrmCampaign {
  id          String            @id @default(cuid())
  tenantId    String?
  tenant      Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  channel     String?
  status      CrmCampaignStatus @default(DRAFT)
  budget      Decimal?          @db.Decimal(12, 2)
  startDate   DateTime?         @db.Date
  endDate     DateTime?         @db.Date
  ownerId     String?
  owner       User?             @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  description String?
  stats       Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     CrmCampaignMember[]

  @@index([tenantId, status])
}

model CrmCampaignMember {
  id         String      @id @default(cuid())
  campaignId String
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId     String?
  email      String?
  phone      String?
  status     String      @default("pending")
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  createdAt  DateTime    @default(now())

  @@index([campaignId])
}

model CrmReferral {
  id             String       @id @default(cuid())
  referrerUserId String?
  referrerCode   String?
  referredEmail  String?
  referredPhone  String?
  customerId     String?
  customer       CrmCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  rewardAmount   Decimal      @default(0) @db.Decimal(10, 2)
  status         String       @default("pending")
  convertedAt    DateTime?
  createdAt      DateTime     @default(now())

  @@index([referrerCode])
  @@index([status])
}

model CrmSupportTicket {
  id           String            @id @default(cuid())
  tenantId     String?
  tenant       Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketNumber String            @unique
  subject      String
  description  String?
  status       CrmTicketStatus   @default(OPEN)
  priority     CrmTicketPriority @default(NORMAL)
  category     String?
  customerId   String?
  customer     CrmCustomer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderId      String?
  assigneeId   String?
  assignee     User?             @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?             @relation("TicketCreator", fields: [createdById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  messages     CrmTicketMessage[]

  @@index([tenantId, status])
  @@index([assigneeId])
  @@index([customerId])
}

model CrmTicketMessage {
  id         String           @id @default(cuid())
  ticketId   String
  ticket     CrmSupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body       String
  isInternal Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([ticketId, createdAt])
}

// ─── Fleet Management Platform ────────────────────────────────────────────────

enum FleetVehicleType {
  TRUCK
  VAN
  MOTORCYCLE
  TANKER
  OTHER
}

enum FleetVehicleStatus {
  ACTIVE
  IN_SERVICE
  INACTIVE
  RETIRED
}

enum FleetMaintenanceType {
  SCHEDULED
  REPAIR
  INSPECTION
  EMERGENCY
}

enum FleetMaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FleetInsuranceStatus {
  ACTIVE
  EXPIRED
  PENDING
  CANCELLED
}

enum FleetTripStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FleetReminderStatus {
  PENDING
  COMPLETED
  OVERDUE
  DISMISSED
}

model FleetVehicle {
  id                String             @id @default(cuid())
  tenantId          String?
  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registrationNo    String             @unique
  name              String
  type              FleetVehicleType   @default(TRUCK)
  status            FleetVehicleStatus @default(ACTIVE)
  make              String?
  model             String?
  year              Int?
  odometerKm        Decimal            @default(0) @db.Decimal(12, 2)
  fuelType          String?
  isTanker          Boolean            @default(false)
  tankCapacityLiters Decimal?          @db.Decimal(10, 2)
  currentTempCelsius Float?
  gpsDeviceId       String?
  currentLat        Decimal?           @db.Decimal(10, 7)
  currentLng        Decimal?           @db.Decimal(10, 7)
  lastGpsAt         DateTime?
  assignedDriverId  String?
  assignedDriver    FleetDriver?       @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  fuelLogs          FleetFuelLog[]
  maintenance       FleetMaintenance[]
  insurance         FleetInsurance[]
  reminders         FleetServiceReminder[]
  trips             FleetTrip[]
  gpsTracks         FleetGpsTrack[]
  routes            FleetRoute[]

  @@index([tenantId, status])
  @@index([isTanker])
}

model FleetDriver {
  id              String         @id @default(cuid())
  tenantId        String?
  tenant          Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNo       String?
  licenseExpiry   DateTime?      @db.Date
  phone           String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  assignedVehicles FleetVehicle[]
  trips           FleetTrip[]

  @@index([tenantId])
}

model FleetFuelLog {
  id          String       @id @default(cuid())
  vehicleId   String
  vehicle     FleetVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  liters      Decimal      @db.Decimal(10, 2)
  cost        Decimal      @db.Decimal(10, 2)
  odometerKm  Decimal?     @db.Decimal(12, 2)
  station     String?
  filledAt    DateTime     @default(now())
  notes       String?
  createdAt   DateTime     @default(now())

  @@index([vehicleId, filledAt])
}

model FleetMaintenance {
  id          String                 @id @default(cuid())
  vehicleId   String
  vehicle     FleetVehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type        FleetMaintenanceType   @default(SCHEDULED)
  status      FleetMaintenanceStatus @default(SCHEDULED)
  title       String
  description String?
  cost        Decimal?               @db.Decimal(10, 2)
  scheduledAt DateTime?
  completedAt DateTime?
  odometerKm  Decimal?               @db.Decimal(12, 2)
  vendor      String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([vehicleId, status])
}

model FleetInsurance {
  id           String               @id @default(cuid())
  vehicleId    String
  vehicle      FleetVehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  provider     String
  policyNo     String
  status       FleetInsuranceStatus @default(ACTIVE)
  premium      Decimal?             @db.Decimal(10, 2)
  coverageAmt  Decimal?             @db.Decimal(12, 2)
  startDate    DateTime             @db.Date
  endDate      DateTime             @db.Date
  documentUrl  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([vehicleId, status])
  @@index([endDate])
}

model FleetServiceReminder {
  id          String              @id @default(cuid())
  vehicleId   String
  vehicle     FleetVehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueAt       DateTime
  dueOdometer Decimal?            @db.Decimal(12, 2)
  status      FleetReminderStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime            @default(now())

  @@index([vehicleId, status])
  @@index([dueAt, status])
}

model FleetGpsTrack {
  id        String       @id @default(cuid())
  vehicleId String
  vehicle   FleetVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  latitude  Decimal      @db.Decimal(10, 7)
  longitude Decimal      @db.Decimal(10, 7)
  speedKmh  Float?
  heading   Float?
  accuracy  Float?
  source    String?
  createdAt DateTime     @default(now())

  @@index([vehicleId, createdAt])
}

model FleetTrip {
  id            String          @id @default(cuid())
  vehicleId     String
  vehicle       FleetVehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId      String?
  driver        FleetDriver?    @relation(fields: [driverId], references: [id], onDelete: SetNull)
  driverUserId  String?
  driverUser    User?           @relation("TripDriver", fields: [driverUserId], references: [id], onDelete: SetNull)
  routeId       String?
  route         FleetRoute?     @relation(fields: [routeId], references: [id], onDelete: SetNull)
  status        FleetTripStatus @default(PLANNED)
  startOdometer Decimal?        @db.Decimal(12, 2)
  endOdometer   Decimal?        @db.Decimal(12, 2)
  distanceKm    Decimal?        @db.Decimal(10, 2)
  fuelUsedLiters Decimal?       @db.Decimal(10, 2)
  milkLiters    Decimal?        @db.Decimal(10, 2)
  startedAt     DateTime?
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([vehicleId, status])
  @@index([driverId])
  @@index([startedAt])
}

model FleetRoute {
  id               String         @id @default(cuid())
  tenantId         String?
  tenant           Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicleId        String?
  vehicle          FleetVehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  name             String
  stops            Json
  optimizedOrder   Json?
  totalDistanceKm  Decimal?       @db.Decimal(10, 2)
  estimatedMinutes Int?
  isOptimized      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  trips            FleetTrip[]

  @@index([tenantId])
  @@index([vehicleId])
}

// ─── Milk Processing Platform ───────────────────────────────────────────────────

enum ProcProductType {
  RAW_MILK
  PANEER
  CURD
  BUTTER
  GHEE
  KHOYA
  LASSI
  FLAVOURED_MILK
}

enum ProcBatchStatus {
  PLANNED
  IN_PROGRESS
  QC_PENDING
  APPROVED
  REJECTED
  PACKAGED
  COMPLETED
  CANCELLED
}

enum ProcQcStatus {
  PENDING
  PASSED
  FAILED
  HOLD
}

enum ProcPackagingType {
  CUP
  POUCH
  TIN
  BOX
  BOTTLE
  BULK
}

enum ProcScheduleStatus {
  DRAFT
  SCHEDULED
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

model ProcRecipe {
  id            String                @id @default(cuid())
  tenantId      String?
  tenant        Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  productType   ProcProductType
  version       Int                   @default(1)
  yieldQty      Decimal               @db.Decimal(10, 2)
  yieldUnit     String                @default("kg")
  milkLiters    Decimal?              @db.Decimal(10, 2)
  shelfLifeDays Int                   @default(7)
  instructions  String?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  ingredients   ProcRecipeIngredient[]
  batches       ProcBatch[]

  @@index([tenantId, productType])
}

model ProcRecipeIngredient {
  id       String     @id @default(cuid())
  recipeId String
  recipe   ProcRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  name     String
  quantity Decimal    @db.Decimal(10, 3)
  unit     String

  @@index([recipeId])
}

model ProcBatch {
  id             String          @id @default(cuid())
  tenantId       String?
  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batchNumber    String          @unique
  productType    ProcProductType
  recipeId       String?
  recipe         ProcRecipe?     @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  status         ProcBatchStatus @default(PLANNED)
  milkInputLiters Decimal?       @db.Decimal(10, 2)
  plannedQty     Decimal?        @db.Decimal(10, 2)
  actualQty      Decimal?        @db.Decimal(10, 2)
  yieldUnit      String          @default("kg")
  expiryDate     DateTime?       @db.Date
  startedAt      DateTime?
  completedAt    DateTime?
  notes          String?
  createdById    String?
  createdBy      User?           @relation("BatchCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  qualityChecks  ProcQualityCheck[]
  packaging      ProcPackaging[]
  labels         ProcLabel[]
  schedules      ProcSchedule[]

  @@index([tenantId, productType, status])
  @@index([expiryDate])
}

model ProcSchedule {
  id           String             @id @default(cuid())
  tenantId     String?
  tenant       Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productType  ProcProductType
  plannedQty   Decimal            @db.Decimal(10, 2)
  yieldUnit    String             @default("kg")
  scheduledDate DateTime          @db.Date
  status       ProcScheduleStatus @default(DRAFT)
  milkRequired Decimal?           @db.Decimal(10, 2)
  batchId      String?
  batch        ProcBatch?         @relation(fields: [batchId], references: [id], onDelete: SetNull)
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([tenantId, scheduledDate])
  @@index([productType, status])
}

model ProcQualityCheck {
  id            String       @id @default(cuid())
  batchId       String
  batch         ProcBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  checkType     String
  parameter     String
  expectedValue String?
  actualValue   String?
  status        ProcQcStatus @default(PENDING)
  notes         String?
  checkedById   String?
  checkedBy     User?        @relation(fields: [checkedById], references: [id], onDelete: SetNull)
  checkedAt     DateTime?
  createdAt     DateTime     @default(now())

  @@index([batchId, status])
}

model ProcPackaging {
  id             String            @id @default(cuid())
  batchId        String
  batch          ProcBatch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  packagingType  ProcPackagingType @default(POUCH)
  unitSize       String?
  unitCount      Int               @default(1)
  totalQty       Decimal           @db.Decimal(10, 2)
  packagedAt     DateTime          @default(now())
  notes          String?
  labels         ProcLabel[]

  @@index([batchId])
}

model ProcLabel {
  id           String         @id @default(cuid())
  batchId      String
  batch        ProcBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  packagingId  String?
  packaging    ProcPackaging? @relation(fields: [packagingId], references: [id], onDelete: SetNull)
  productType  ProcProductType
  barcode      String         @unique
  qrPayload    String
  expiryDate   DateTime       @db.Date
  generatedAt  DateTime       @default(now())

  @@index([batchId])
  @@index([expiryDate])
  @@index([barcode])
}

// ─── Retail Billing / POS Platform ──────────────────────────────────────────────

enum PosBillStatus {
  DRAFT
  COMPLETED
  VOID
  PARTIALLY_RETURNED
  FULLY_RETURNED
}

enum PosPaymentMethod {
  CASH
  UPI
  CARD
  WALLET
  LOYALTY
}

enum PosReturnType {
  RETURN
  EXCHANGE
}

enum PosReturnStatus {
  PENDING
  APPROVED
  REFUNDED
  EXCHANGED
  REJECTED
}

enum PosOfflineStatus {
  PENDING
  SYNCED
  FAILED
}

model PosTerminal {
  id                String   @id @default(cuid())
  tenantId          String?
  tenant            Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String
  location          String?
  printerName       String?
  printerWidth      Int      @default(80)
  cashDrawerEnabled Boolean  @default(true)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  bills             PosBill[]
  offlineQueue      PosOfflineQueue[]

  @@index([tenantId])
}

model PosProductBarcode {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  barcode   String   @unique
  qrPayload String?
  createdAt DateTime @default(now())

  @@index([productId])
}

model PosBill {
  id               String         @id @default(cuid())
  tenantId         String?
  tenant           Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminalId       String?
  terminal         PosTerminal?   @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  billNumber       String         @unique
  status           PosBillStatus  @default(DRAFT)
  cashierId        String?
  cashier          User?          @relation("PosCashier", fields: [cashierId], references: [id], onDelete: SetNull)
  customerUserId   String?
  customerPhone    String?
  customerName     String?
  customerGstin    String?
  subtotal         Decimal        @default(0) @db.Decimal(12, 2)
  discountAmount   Decimal        @default(0) @db.Decimal(10, 2)
  discountPercent  Decimal        @default(0) @db.Decimal(5, 2)
  loyaltyRedeemed  Decimal        @default(0) @db.Decimal(10, 2)
  loyaltyEarned    Int            @default(0)
  taxCgst          Decimal        @default(0) @db.Decimal(10, 2)
  taxSgst          Decimal        @default(0) @db.Decimal(10, 2)
  taxIgst          Decimal        @default(0) @db.Decimal(10, 2)
  total            Decimal        @default(0) @db.Decimal(12, 2)
  invoiceNumber    String?        @unique
  invoiceType      String         @default("B2C")
  billBarcode      String?        @unique
  billQrPayload    String?
  isOffline        Boolean        @default(false)
  offlineClientId  String?
  cashDrawerOpened Boolean        @default(false)
  printedAt        DateTime?
  syncedAt         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  items            PosBillItem[]
  payments         PosBillPayment[]
  returns          PosReturn[]
  loyaltyTxns      PosLoyaltyTransaction[]

  @@index([tenantId, status])
  @@index([cashierId])
  @@index([createdAt])
  @@index([offlineClientId])
}

model PosBillItem {
  id            String   @id @default(cuid())
  billId        String
  bill          PosBill  @relation(fields: [billId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  barcodeScanned String?
  name          String
  hsnCode       String   @default("0401")
  quantity      Decimal  @db.Decimal(10, 3)
  unitPrice     Decimal  @db.Decimal(10, 2)
  discount      Decimal  @default(0) @db.Decimal(10, 2)
  taxRate       Decimal  @default(5) @db.Decimal(5, 2)
  cgst          Decimal  @default(0) @db.Decimal(10, 2)
  sgst          Decimal  @default(0) @db.Decimal(10, 2)
  lineTotal     Decimal  @db.Decimal(12, 2)

  @@index([billId])
}

model PosBillPayment {
  id        String           @id @default(cuid())
  billId    String
  bill      PosBill          @relation(fields: [billId], references: [id], onDelete: Cascade)
  method    PosPaymentMethod
  amount    Decimal          @db.Decimal(10, 2)
  reference String?
  createdAt DateTime         @default(now())

  @@index([billId])
}

model PosLoyaltyAccount {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  phone           String?  @unique
  customerName    String?
  pointsBalance   Int      @default(0)
  lifetimePoints  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  transactions    PosLoyaltyTransaction[]

  @@index([phone])
}

model PosLoyaltyTransaction {
  id          String            @id @default(cuid())
  accountId   String
  account     PosLoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  billId      String?
  bill        PosBill?          @relation(fields: [billId], references: [id], onDelete: SetNull)
  type        String
  points      Int
  balanceAfter Int
  notes       String?
  createdAt   DateTime          @default(now())

  @@index([accountId])
}

model PosReturn {
  id              String          @id @default(cuid())
  returnNumber    String          @unique
  originalBillId  String
  originalBill    PosBill         @relation(fields: [originalBillId], references: [id], onDelete: Cascade)
  type            PosReturnType
  status          PosReturnStatus @default(PENDING)
  reason          String?
  refundAmount    Decimal         @default(0) @db.Decimal(10, 2)
  exchangeBillId  String?
  processedById   String?
  processedAt     DateTime?
  createdAt       DateTime        @default(now())
  items           PosReturnItem[]

  @@index([originalBillId])
}

model PosReturnItem {
  id         String    @id @default(cuid())
  returnId   String
  posReturn  PosReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  billItemId String
  quantity   Decimal   @db.Decimal(10, 3)
  amount     Decimal   @db.Decimal(10, 2)

  @@index([returnId])
}

model PosOfflineQueue {
  id           String           @id @default(cuid())
  clientId     String           @unique
  terminalId   String?
  terminal     PosTerminal?     @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  payload      Json
  status       PosOfflineStatus @default(PENDING)
  errorMessage String?
  billId       String?
  createdAt    DateTime         @default(now())
  syncedAt     DateTime?

  @@index([status])
}

// ─── AI Platform ────────────────────────────────────────────────────────────────

enum AiModule {
  CEO
  FINANCE
  FARM
  INVENTORY
  MARKETING
  SALES
  CUSTOMER
  VOICE
  WHATSAPP
  AGENT
}

enum AiModuleRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model AiModuleRun {
  id        String            @id @default(cuid())
  module    AiModule
  status    AiModuleRunStatus @default(RUNNING)
  input     String?           @db.Text
  output    String?           @db.Text
  insights  Json?
  userId    String?
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  farmId    String            @default("default")
  createdAt DateTime          @default(now())
  completedAt DateTime?

  @@index([module, createdAt])
  @@index([userId])
}

model AiWhatsAppSession {
  id            String   @id @default(cuid())
  phone         String
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  locale        String   @default("hi-IN")
  status        String   @default("active")
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  messages      AiWhatsAppMessage[]

  @@unique([phone])
  @@index([lastMessageAt])
}

model AiWhatsAppMessage {
  id        String            @id @default(cuid())
  sessionId String
  session   AiWhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  direction String
  body      String            @db.Text
  aiReply   String?           @db.Text
  metadata  Json?
  createdAt DateTime          @default(now())

  @@index([sessionId, createdAt])
}

model AiAgentDefinition {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  tools           Json
  requiresConfirm Boolean  @default(true)
  isAutonomous    Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── SaaS Global Platform (Marketplace · Partners · Regional) ───────────────────

enum SaasListingType {
  APP
  PLUGIN
  INTEGRATION
  API
}

enum SaasPartnerType {
  PARTNER
  RESELLER
}

model SaasMarketplaceListing {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  type        SaasListingType @default(APP)
  category    String?
  description String?
  price       Decimal         @default(0) @db.Decimal(10, 2)
  currency    String          @default("INR")
  iconUrl     String?
  entryPoint  String?
  isPublished Boolean         @default(true)
  isFeatured  Boolean         @default(false)
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  installs    SaasMarketplaceInstall[]

  @@index([type, isPublished])
}

model SaasMarketplaceInstall {
  id        String                 @id @default(cuid())
  tenantId  String
  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listingId String
  listing   SaasMarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  status    String                 @default("active")
  installedAt DateTime             @default(now())

  @@unique([tenantId, listingId])
  @@index([tenantId])
}

model SaasPartner {
  id              String            @id @default(cuid())
  type            SaasPartnerType
  name            String
  slug            String            @unique
  email           String?
  phone           String?
  commissionRate  Decimal           @default(10) @db.Decimal(5, 2)
  isActive        Boolean           @default(true)
  portalConfig    Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  members         SaasPartnerMember[]
  tenants         SaasPartnerTenant[]

  @@index([type, isActive])
}

model SaasPartnerMember {
  id        String      @id @default(cuid())
  partnerId String
  partner   SaasPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String      @default("member")
  createdAt DateTime    @default(now())

  @@unique([partnerId, userId])
  @@index([userId])
}

model SaasPartnerTenant {
  id             String      @id @default(cuid())
  partnerId      String
  partner        SaasPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  commissionRate Decimal?    @db.Decimal(5, 2)
  onboardedAt    DateTime    @default(now())

  @@unique([partnerId, tenantId])
  @@index([tenantId])
}

model TenantRegionalSettings {
  tenantId         String   @id
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultCurrency  String   @default("INR")
  enabledCurrencies String[] @default(["INR", "USD", "EUR", "AED"])
  defaultCountry   String   @default("IN")
  enabledCountries String[] @default(["IN", "US", "AE", "GB"])
  defaultLocale    String   @default("en")
  enabledLocales   String[] @default(["en", "hi", "ar"])
  timezone         String   @default("Asia/Kolkata")
  updatedAt        DateTime @updatedAt
}

model TenantTaxRule {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  countryCode String
  taxName     String
  taxType     String   @default("GST")
  rate        Decimal  @db.Decimal(5, 2)
  isInclusive Boolean  @default(false)
  hsnCode     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([tenantId, countryCode])
}

model TenantShippingZone {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  countries   String[]
  carrier     String?
  baseRate    Decimal  @default(0) @db.Decimal(10, 2)
  perKgRate   Decimal? @db.Decimal(10, 2)
  freeAbove   Decimal? @db.Decimal(10, 2)
  currency    String   @default("INR")
  etaDays     Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([tenantId])
}
