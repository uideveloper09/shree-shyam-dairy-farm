{
  "name": "shree-shyam-dairy-farm",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "env:validate": "npx tsx scripts/validate-env.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed-farm": "npx tsx prisma/seed-farm-run.ts",
    "db:seed-tenant": "npx tsx prisma/seed-tenant.ts",
    "db:seed-notifications": "npx tsx prisma/seed-notifications.ts",
    "db:seed-workflows": "npx tsx prisma/seed-workflows.ts",
    "db:seed-documents": "npx tsx prisma/seed-documents.ts",
    "db:seed-integrations": "npx tsx prisma/seed-integrations.ts",
    "db:seed-crm": "npx tsx prisma/seed-crm.ts",
    "db:seed-fleet": "npx tsx prisma/seed-fleet.ts",
    "db:seed-processing": "npx tsx prisma/seed-processing.ts",
    "db:seed-retail": "npx tsx prisma/seed-retail.ts",
    "db:seed-ai": "npx tsx prisma/seed-ai.ts",
    "db:seed-saas": "npx tsx prisma/seed-saas.ts",
    "db:studio": "prisma studio",
    "worker:mqtt": "npx tsx workers/mqtt-bridge.worker.ts",
    "worker:queue": "npx tsx workers/queue.worker.ts",
    "worker:webhooks": "npx tsx workers/webhook-retry.worker.ts",
    "docker:dev": "docker compose up",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d",
    "docker:monitoring": "docker compose -f docker-compose.monitoring.yml up -d",
    "backup:db": "bash scripts/backup-db.sh",
    "backup:files": "bash scripts/backup-files.sh"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.101.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.0",
    "framer-motion": "^12.40.0",
    "ioredis": "^5.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "mqtt": "^5.15.1",
    "nanoid": "^5.1.16",
    "next": "16.2.9",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "server-only": "^0.0.1",
    "sharp": "^0.35.2",
    "stripe": "^17.7.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pino-pretty": "^4.7.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.5.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
